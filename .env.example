# Copy this file to ".env.local" and fill in your keys.
# The app runs fully in "Practice Mode" without any keys, so you can try it first.

# --- Writing feedback & turning stories into scenes (OpenAI) ---
OPENAI_API_KEY=
# Optional: which text model to use (default: gpt-4o-mini)
OPENAI_TEXT_MODEL=gpt-4o-mini
# Optional: text-to-speech model used to voice characters' lines in the movie
# (default: gpt-4o-mini-tts). Without an OpenAI key, the app falls back to the
# free built-in browser voice.
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# --- Turning scenes into images & videos (Replicate) ---
REPLICATE_API_TOKEN=
# Optional: any text-to-image model on Replicate for the storyboard previews
# (default: black-forest-labs/flux-schnell -- fast & cheap, great for iterating)
# This model also draws the one-time "character reference sheet" anchor.
REPLICATE_IMAGE_MODEL=black-forest-labs/flux-schnell

# --- Character consistency between scenes ---
# Each scene is redrawn from a one-time character "reference sheet" using a
# reference-capable image model, so the same characters appear in every scene.
# Default: google/nano-banana-2 (Gemini Flash Image) -- purpose-built for
# keeping characters consistent across different scenes. Set to "" to disable
# (text-only consistency).
REPLICATE_IMAGE_REF_MODEL=google/nano-banana-2
# The model's source-image input field. Nano Banana uses "image_input" (array).
# For FLUX Kontext use "input_image" and set the ARRAY flag to false.
REPLICATE_IMAGE_REF_KEY=image_input
REPLICATE_IMAGE_REF_KEY_ARRAY=true
# --- Character / art-style consistency ---
# By DEFAULT the app animates the approved storyboard image (image-to-video), so
# each video clip matches the storyboard's characters and art style exactly.
# Default i2v model: wan-video/wan-2.2-i2v-fast (fast, cheap, silent, 16:9).
REPLICATE_VIDEO_MODEL=wan-video/wan-2.2-i2v-fast
REPLICATE_VIDEO_MODE=i2v
# The input field your i2v model uses for the source image (wan i2v uses "image";
# some models use "first_frame" or "start_image").
REPLICATE_VIDEO_IMAGE_KEY=image
# Prefer plain text-to-video instead? Set:
#   REPLICATE_VIDEO_MODE=t2v
#   REPLICATE_VIDEO_MODEL=wan-video/wan-2.2-t2v-fast
# The app still builds a "story bible" (one art style + locked character looks)
# and injects it into every image and video prompt for consistency.
